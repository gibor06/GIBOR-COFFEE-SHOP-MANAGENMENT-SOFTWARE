<UserControl x:Class="CoffeeShop.Wpf.Views.NhaCungCapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="980">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="300" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Quản lý nhà cung cấp" />
                        <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Lưu thông tin liên hệ nhà cung cấp để nhập hàng nhanh và chính xác." />

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Tên nhà cung cấp" />
                        <TextBox Text="{Binding TenNhaCungCap, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" />

                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Số điện thoại" />
                        <TextBox Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}" MaxLength="15" />

                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Địa chỉ" />
                        <TextBox Height="70"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="300" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Tạo mới"
                                Width="120"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TaoMoiCommand}" />
                            <Button Content="Làm mới"
                                Width="100"
                                Margin="8,0,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                        </WrapPanel>

                        <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                        <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Tìm kiếm nhà cung cấp" />
                        <TextBox Margin="0,8,0,0"
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="0,8,0,0"
                            Content="Tìm kiếm"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding TimKiemCommand}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                <DataGrid ItemsSource="{Binding NhaCungCaps}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding NhaCungCapId}" Width="80" />
                        <DataGridTextColumn Header="Tên nhà cung cấp" Binding="{Binding TenNhaCungCap}" Width="2*" />
                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="130" />
                        <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="3*" />
                        <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="160" />
                        <DataGridCheckBoxColumn Header="Kích hoạt" Binding="{Binding IsActive}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
