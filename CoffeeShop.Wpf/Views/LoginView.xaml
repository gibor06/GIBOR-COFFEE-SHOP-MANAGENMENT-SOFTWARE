<UserControl x:Class="CoffeeShop.Wpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infra="clr-namespace:CoffeeShop.Wpf.Infrastructure"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="760" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1"
                Style="{StaticResource CardPanel}"
                Padding="0"
                Margin="0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="12,0,0,12"
                        Padding="28">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GIBOR COFFEE"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{DynamicResource SidebarMutedTextBrush}"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Text="Khách hàng là người trả lương cho bạn." />

                        <Border Margin="0,24,0,0"
                                Background="{DynamicResource SidebarPanelBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            
                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="120"
                                         Height="120"
                                         Stroke="{DynamicResource CardBorderBrush}"
                                         StrokeThickness="1.5">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="pack://application:,,,/CoffeeShop.Wpf;component/Resources/Images/Logo.jpg"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Đăng nhập hệ thống" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="Vui lòng nhập thông tin tài khoản để tiếp tục." />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock FontWeight="SemiBold" Text="Tên đăng nhập" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock FontWeight="SemiBold" Text="Mật khẩu" />
                        <PasswordBox infra:PasswordBoxHelper.Attach="True"
                                     infra:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,7"
                                     Margin="0,6,0,0" />
                    </StackPanel>

                    <Button Grid.Row="6"
                            Content="Đăng nhập"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding LoginCommand}" 
                            IsDefault="True"
                            />

                    <TextBlock Grid.Row="8"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

