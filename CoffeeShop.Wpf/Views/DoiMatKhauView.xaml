<UserControl x:Class="CoffeeShop.Wpf.Views.DoiMatKhauView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infra="clr-namespace:CoffeeShop.Wpf.Infrastructure"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="760">
    <Grid>
        <Border Style="{StaticResource CardPanel}"
                Width="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Đổi mật khẩu" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Đổi mật khẩu để tăng an toàn cho tài khoản đang đăng nhập." />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Mật khẩu cũ" />
                <PasswordBox infra:PasswordBoxHelper.Attach="True"
                             infra:PasswordBoxHelper.BoundPassword="{Binding MatKhauCu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7"
                             Margin="0,6,0,0" />

                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Mật khẩu mới" />
                <PasswordBox infra:PasswordBoxHelper.Attach="True"
                             infra:PasswordBoxHelper.BoundPassword="{Binding MatKhauMoi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7"
                             Margin="0,6,0,0" />

                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Xác nhận mật khẩu mới" />
                <PasswordBox infra:PasswordBoxHelper.Attach="True"
                             infra:PasswordBoxHelper.BoundPassword="{Binding XacNhanMatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7"
                             Margin="0,6,0,0" />

                <WrapPanel Margin="0,14,0,0">
                    <Button Width="130"
                            Content="Đổi mật khẩu"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding DoiMatKhauCommand}" />
                    <Button Width="100"
                            Margin="8,0,0,0"
                            Content="Làm mới"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding LamMoiCommand}" />
                </WrapPanel>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
