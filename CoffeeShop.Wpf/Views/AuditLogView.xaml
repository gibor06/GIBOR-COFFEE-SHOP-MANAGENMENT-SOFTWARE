<UserControl x:Class="CoffeeShop.Wpf.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550"
             d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  >

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Nhật ký thao tác"
                               FontSize="22"
                               FontWeight="SemiBold" />

                    <WrapPanel Margin="0,12,0,0">
                        <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                        <DatePicker Margin="8,0,0,0"
                                    SelectedDate="{Binding ToDate, Mode=TwoWay}" />

                        <TextBox Width="170"
                                 Margin="8,0,0,0"
                                 Style="{StaticResource HintTextBoxStyle}"
                                 Tag="Nhập hành động"
                                 Text="{Binding HanhDong, UpdateSourceTrigger=PropertyChanged}"
                        />

                        <TextBox Width="220"
                                 Margin="8,0,0,0"
                                 Style="{StaticResource HintTextBoxStyle}"
                                 Tag="Nhập từ khóa"
                                 Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}" 
                        />

                        <Button Width="100"
                                Margin="8,10,0,0"
                                Content="Tìm kiếm"
                                Command="{Binding TimKiemCommand}" />

                        <Button Width="90"
                                Margin="8,10,0,0"
                                Content="Làm mới"
                                Command="{Binding LamMoiCommand}"
                                Background="{DynamicResource SecondaryBrush}"
                                BorderBrush="{DynamicResource SecondaryBrush}"
                                Foreground="{DynamicResource SecondaryTextBrush}" />
                    </WrapPanel>

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10"
                    Padding="12">
                <DataGrid ItemsSource="{Binding DanhSachLog}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          Height="350"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã log" Binding="{Binding AuditLogId}" Width="70" />
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding ThoiGianTao, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="150" />
                        <DataGridTextColumn Header="Người dùng" Binding="{Binding TenDangNhap}" Width="110" />
                        <DataGridTextColumn Header="Hành động" Binding="{Binding HanhDong}" Width="170" />
                        <DataGridTextColumn Header="Đối tượng" Binding="{Binding DoiTuong}" Width="120" />
                        <DataGridTextColumn Header="Nội dung" Binding="{Binding DuLieuTomTat}" Width="250" />
                        <DataGridTextColumn Header="Máy trạm" Binding="{Binding MayTram}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>


