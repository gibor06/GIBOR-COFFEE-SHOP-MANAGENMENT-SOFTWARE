<UserControl x:Class="CoffeeShop.Wpf.Views.ThongKeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="820"
             d:DesignWidth="1250">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleText}" Text="Thống kê doanh thu" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource PageSubtitleText}"
                               Text="Theo dõi doanh thu, top sản phẩm và danh sách hóa đơn theo khoảng thời gian." />

                    <WrapPanel Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Từ ngày" />
                            <DatePicker Width="170" SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Đến ngày" />
                            <DatePicker Width="170" SelectedDate="{Binding ToDate, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Margin="14,19,0,0"
                                Width="130"
                                Content="Tải thống kê"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TaiThongKeCommand}" />
                        <Button Margin="8,19,0,0"
                                Width="100"
                                Content="Làm mới"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                    </WrapPanel>

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Tổng số hóa đơn" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding TongSoHoaDon}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Doanh thu gộp" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="{Binding TongDoanhThuGop, StringFormat={}{0:N0} đ}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding TongGiamGia, StringFormat=Giảm giá: {0:N0} đ}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Doanh thu thuần" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="{Binding TongDoanhThuThuan, StringFormat={}{0:N0} đ}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource CardTitleText}" Text="Doanh thu theo ngày" />
                        <DataGrid Grid.Row="2" ItemsSource="{Binding DoanhThuTheoNgay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ngày" Binding="{Binding Ngay, StringFormat=dd/MM/yyyy}" Width="120" />
                                <DataGridTextColumn Header="Số HĐ"
                                                    Binding="{Binding SoHoaDon}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Doanh thu gộp"
                                                    Binding="{Binding DoanhThuGop, StringFormat={}{0:N0} đ}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="140" />
                                <DataGridTextColumn Header="Giảm giá"
                                                    Binding="{Binding GiamGia, StringFormat={}{0:N0} đ}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Doanh thu thuần"
                                                    Binding="{Binding DoanhThuThuan, StringFormat={}{0:N0} đ}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource CardTitleText}" Text="Top 10 sản phẩm bán chạy" />
                        <DataGrid Grid.Row="2" ItemsSource="{Binding TopSanPhamBanChay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="70" />
                                <DataGridTextColumn Header="Tên món" Binding="{Binding TenMon}" Width="*" />
                                <DataGridTextColumn Header="SL bán"
                                                    Binding="{Binding TongSoLuongBan}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Số HĐ"
                                                    Binding="{Binding SoHoaDon}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Doanh thu"
                                                    Binding="{Binding TongDoanhThu, StringFormat={}{0:N0} đ}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="130" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="6" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource CardTitleText}" Text="Danh sách hóa đơn bán" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachHoaDon}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding HoaDonBanId}" Width="80" />
                            <DataGridTextColumn Header="Ngày bán" Binding="{Binding NgayBan, StringFormat=dd/MM/yyyy HH:mm}" Width="150" />
                            <DataGridTextColumn Header="Tổng tiền"
                                                Binding="{Binding TongTien, StringFormat={}{0:N0} đ}"
                                                ElementStyle="{StaticResource RightAlignedCellText}"
                                                Width="130" />
                            <DataGridTextColumn Header="Giảm giá"
                                                Binding="{Binding GiamGia, StringFormat={}{0:N0} đ}"
                                                ElementStyle="{StaticResource RightAlignedCellText}"
                                                Width="120" />
                            <DataGridTextColumn Header="Thành toán"
                                                Binding="{Binding ThanhToan, StringFormat={}{0:N0} đ}"
                                                ElementStyle="{StaticResource RightAlignedCellText}"
                                                Width="130" />
                            <DataGridTextColumn Header="Người tạo" Binding="{Binding CreatedByUserId}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
