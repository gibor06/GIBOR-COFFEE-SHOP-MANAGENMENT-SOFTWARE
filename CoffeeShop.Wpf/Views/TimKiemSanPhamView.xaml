<UserControl x:Class="CoffeeShop.Wpf.Views.TimKiemSanPhamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="980">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Tìm kiếm sản phẩm" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Tra cứu sản phẩm theo từ khóa và danh mục để thao tác kho nhanh hơn." />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding DanhMucs}"
                              SelectedItem="{Binding SelectedDanhMuc, Mode=TwoWay}"
                              DisplayMemberPath="TenDanhMuc" />

                    <Button Grid.Column="4"
                            Width="110"
                            Content="Tìm kiếm"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding TimKiemCommand}" />

                    <Button Grid.Column="6"
                            Width="100"
                            Content="Làm mới"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding LamMoiCommand}" />
                </Grid>

                <TextBlock Margin="0,10,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <DataGrid ItemsSource="{Binding KetQuaMon}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="80" />
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                    <DataGridTextColumn Header="Danh mục" Binding="{Binding TenDanhMuc}" Width="180" />
                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat=N0}" Width="120" />
                    <DataGridTextColumn Header="Tồn kho" Binding="{Binding TonKho}" Width="100" />
                    <DataGridTextColumn Header="Hình ảnh" Binding="{Binding HinhAnhPath}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
