<UserControl x:Class="CoffeeShop.Wpf.Views.HoaDonBanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="780"
             d:DesignWidth="1220">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleText}" Text="Hóa đơn bán" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource PageSubtitleText}"
                           Text="Chọn bàn, chọn khách hàng, thêm món và thanh toán nhanh cho thu ngân." />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource CaptionText}"
                           Text="{Binding ThongTinCaLamViec}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleText}" Text="Thông tin bán hàng" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Bàn phục vụ" />
                            <ComboBox ItemsSource="{Binding Bans}"
                                      SelectedItem="{Binding SelectedBan, Mode=TwoWay}"
                                      DisplayMemberPath="TenBanHienThi" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Khách hàng" />
                            <ComboBox ItemsSource="{Binding KhachHangs}"
                                      SelectedItem="{Binding SelectedKhachHang, Mode=TwoWay}"
                                      DisplayMemberPath="HienThi" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Khuyến mãi" />
                            <ComboBox ItemsSource="{Binding KhuyenMais}"
                                      SelectedItem="{Binding SelectedKhuyenMai, Mode=TwoWay}"
                                      DisplayMemberPath="TenKhuyenMai" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource CardPanelMuted}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Mons}"
                                      SelectedItem="{Binding SelectedMon, Mode=TwoWay}"
                                      DisplayMemberPath="TenMon" />

                            <TextBox Grid.Column="2"
                                     Text="{Binding SoLuongBan, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBox Grid.Column="4"
                                     Text="{Binding DonGiaBan, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Column="6"
                                    Width="130"
                                    Content="Thêm món"
                                    Style="{StaticResource ButtonPrimary}"
                                    Command="{Binding ThemDongCommand}" />
                        </Grid>
                    </Border>

                    <WrapPanel Margin="0,12,0,0">
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelText}"
                                   Text="Giảm giá khác" />
                        <TextBox Width="170"
                                 Margin="8,0,0,0"
                                 Text="{Binding GiamGia, UpdateSourceTrigger=PropertyChanged}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleText}" Text="Thanh toán" />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="{Binding TongTien, StringFormat=Tổng tiền: {0:N0} đ}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding SoTienGiamKhuyenMai, StringFormat=Giảm khuyến mãi: {0:N0} đ}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="{Binding ThanhToan, StringFormat=Thành toán: {0:N0} đ}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DiemCongDuKien, StringFormat=Điểm cộng dự kiến: {0}}" />

                    <!-- Hình thức thanh toán -->
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Hình thức thanh toán" />
                        <ComboBox ItemsSource="{Binding DanhSachHinhThucThanhToan}"
                                  SelectedItem="{Binding HinhThucThanhToanDuocChon, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Tiền khách đưa (chỉ hiện khi tiền mặt) -->
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsThanhToanTienMat}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Tiền khách đưa" />
                        <TextBox Text="{Binding TienKhachDuaText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding TienThoiLai, StringFormat=Tiền trả lại cho khách: {0:N0} đ}" />
                    </StackPanel>

                    <!-- Mã giao dịch (chỉ hiện khi không phải tiền mặt) -->
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsThanhToanTienMat}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Mã giao dịch" />
                        <TextBox Text="{Binding MaGiaoDich, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Ghi chú thanh toán -->
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Ghi chú thanh toán" />
                        <TextBox Text="{Binding GhiChuThanhToan, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Ghi chú hóa đơn -->
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Ghi chú hóa đơn" />
                        <TextBox Text="{Binding GhiChuHoaDon, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button Content="Lưu hóa đơn"
                            Margin="0,10,0,0"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding LuuHoaDonCommand}" />
                    <Button Content="Làm mới"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding LamMoiCommand}" />
                    <Button Content="Xóa dòng chọn"
                            Style="{StaticResource ButtonDanger}"
                            Command="{Binding XoaDongCommand}" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource CardTitleText}" Text="Chi tiết hóa đơn bán" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding ChiTietLines}"
                          SelectedItem="{Binding SelectedDongChiTiet, Mode=TwoWay}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã món" Binding="{Binding MonId}" Width="88" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                        <DataGridTextColumn Header="Số lượng"
                                            Binding="{Binding SoLuong}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="100" />
                        <DataGridTextColumn Header="Đơn giá bán"
                                            Binding="{Binding DonGiaBan, StringFormat={}{0:N0} đ}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="135" />
                        <DataGridTextColumn Header="Thành tiền"
                                            Binding="{Binding ThanhTien, StringFormat={}{0:N0} đ}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        </Grid>

    </ScrollViewer>
</UserControl>
