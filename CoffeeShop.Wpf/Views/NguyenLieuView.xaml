<UserControl x:Class="CoffeeShop.Wpf.Views.NguyenLieuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="980">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="{Binding FormTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Tạo nhanh nguyên liệu mới và quản lý tồn kho nguyên liệu thô (cà phê, sữa, đường...)." />

                    <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Tên nguyên liệu" />
                    <TextBox Text="{Binding TenNguyenLieu, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" />

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Text="Đơn vị tính" />
                            <TextBox Text="{Binding DonViTinh, UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Ví dụ: kg, lít, chai, cái" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Text="Đơn giá nhập" />
                            <TextBox Text="{Binding DonGiaNhap, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Text="Tồn kho nguyên liệu ban đầu" />
                            <TextBox Text="{Binding TonKho, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Số lượng nguyên liệu thô (kg/lít/gram...)" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Text="Ngưỡng cảnh báo nguyên liệu" />
                            <TextBox Text="{Binding TonKhoToiThieu, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Cảnh báo khi tồn nguyên liệu ≤ giá trị này" />
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Width="120"
                                Content="{Binding SubmitButtonText}"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TaoMoiCommand}" />
                        <Button Width="100"
                                Margin="8,0,0,0"
                                Content="Làm mới"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                        <Button Width="120"
                                Margin="8,0,0,0"
                                Content="Hủy chỉnh sửa"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding HuyChinhSuaCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </WrapPanel>

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Bộ lọc tìm kiếm" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Lọc nhanh theo tên nguyên liệu." />

                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Từ khóa" />
                    <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" />

                    <WrapPanel Margin="0,14,0,0">
                        <Button Width="110"
                                Content="Tìm kiếm"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TimKiemCommand}" />
                        <Button Width="110"
                                Margin="8,0,0,0"
                                Content="Làm mới"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="350" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="Danh sách nguyên liệu" />

                <DataGrid Grid.Row="2"
                          Grid.Column="0"
                          ItemsSource="{Binding NguyenLieus}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding NguyenLieuId}" Width="80" />
                        <DataGridTextColumn Header="Tên nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="2*" />
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="100" />
                        <DataGridTextColumn Header="Tồn kho" Binding="{Binding TonKho, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Tồn tối thiểu" Binding="{Binding TonKhoToiThieu, StringFormat=N2}" Width="120" />
                        <DataGridTemplateColumn Header="Trạng thái tồn" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TrangThaiTonKhoHienThi}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrangThaiTonKhoHienThi}" Value="Hết hàng">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThaiTonKhoHienThi}" Value="Sắp hết">
                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Đơn giá nhập" Binding="{Binding DonGiaNhap, StringFormat=N0}" Width="120" />
                        <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="160" />
                        <DataGridTemplateColumn Header="Hành động" Width="240">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Sửa"
                                                Width="60"
                                                Margin="2"
                                                Style="{StaticResource ButtonPrimary}"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Xóa"
                                                Width="60"
                                                Margin="2"
                                                Style="{StaticResource ButtonDanger}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Chi tiết"
                                                Width="70"
                                                Margin="2"
                                                Style="{StaticResource ButtonSecondary}"
                                                Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="2"
                        Style="{StaticResource CardPanel}"
                        Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Chi tiết nguyên liệu" />

                            <Separator Margin="0,8,0,8" />

                            <TextBlock FontWeight="SemiBold" Text="Mã nguyên liệu" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.NguyenLieuId}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Tên nguyên liệu" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedNguyenLieu.TenNguyenLieu}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Đơn vị tính" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.DonViTinh}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Tồn kho hiện tại" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.TonKhoHienThi}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Tồn kho tối thiểu" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.TonKhoToiThieu, StringFormat=N2}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Trạng thái tồn kho" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedNguyenLieu.TrangThaiTonKhoHienThi}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNguyenLieu.TrangThaiTonKhoHienThi}" Value="Hết hàng">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedNguyenLieu.TrangThaiTonKhoHienThi}" Value="Sắp hết">
                                                <Setter Property="Foreground" Value="#FF9800" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Đơn giá nhập" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.DonGiaNhapHienThi}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Trạng thái hoạt động" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedNguyenLieu.TrangThaiHoatDongHienThi}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNguyenLieu.IsActive}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Ngày tạo" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.CreatedAt, StringFormat=dd/MM/yyyy HH:mm:ss}" />

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Ngày cập nhật" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="14"
                                       Text="{Binding SelectedNguyenLieu.UpdatedAt, StringFormat=dd/MM/yyyy HH:mm:ss, TargetNullValue='Chưa cập nhật'}" />

                            <Button Margin="0,16,0,0"
                                    Content="Đóng"
                                    Style="{StaticResource ButtonSecondary}"
                                    Click="CloseDetailButton_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
