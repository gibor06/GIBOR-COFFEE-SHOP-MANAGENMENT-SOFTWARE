<UserControl x:Class="CoffeeShop.Wpf.Views.ExportPrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Xuất / In dữ liệu"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <WrapPanel Margin="0,12,0,0">
                    <TextBlock VerticalAlignment="Center" Text="Từ ngày:" />
                    <DatePicker Margin="6,0,0,0"
                                SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Text="Đến ngày:" />
                    <DatePicker Margin="6,0,0,0"
                                SelectedDate="{Binding ToDate, Mode=TwoWay}" />
                </WrapPanel>

                <WrapPanel Margin="0,8,0,0">
                    <TextBlock VerticalAlignment="Center" Text="Mã hóa đơn bán:" />
                    <TextBox Width="120"
                             Margin="6,0,0,0"
                             Padding="10,6"
                             Text="{Binding HoaDonBanIdInput, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Text="Thư mục xuất (tùy chọn):" />
                    <TextBox Width="360"
                             Margin="6,0,0,0"
                             Padding="10,6"
                             Text="{Binding ThuMucXuat, UpdateSourceTrigger=PropertyChanged}" />
                </WrapPanel>

                <WrapPanel Margin="0,12,0,0">
                    <Button Width="180"
                            Content="Xuất PDF báo cáo đơn giản"
                            Command="{Binding XuatPdfBaoCaoDonGianCommand}" />
                    <Button Width="180"
                            Margin="8,0,0,0"
                            Content="Xuất PDF báo cáo nâng cao"
                            Command="{Binding XuatPdfBaoCaoNangCaoCommand}" />
                    <Button Width="180"
                            Margin="8,0,0,0"
                            Content="Xuất Excel thống kê"
                            Command="{Binding XuatExcelThongKeCommand}" />
                </WrapPanel>

                <WrapPanel Margin="0,8,0,0">
                    <Button Width="180"
                            Content="In hóa đơn bán"
                            Command="{Binding InHoaDonCommand}" />

                    <ComboBox Width="140"
                              Margin="8,0,0,0"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding LoaiPreview, Mode=TwoWay}">
                        <ComboBoxItem Content="Preview đơn giản" Tag="DonGian" IsSelected="True" />
                        <ComboBoxItem Content="Preview nâng cao" Tag="NangCao" />
                    </ComboBox>
                    <Button Width="140"
                            Margin="8,0,0,0"
                            Content="Preview báo cáo"
                            Command="{Binding PreviewBaoCaoCommand}" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding LastOutputPath}"
                           TextWrapping="Wrap"
                           Opacity="0.8" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="14">
            <StackPanel>
                <TextBlock Text="Ghi chú sử dụng"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0"
                           Text="• Chọn PDF khi cần in đúng mẫu hoặc gửi file cho người khác." />
                <TextBlock Text="• Chọn Excel khi cần kiểm tra, lọc hoặc chỉnh sửa dữ liệu sau khi xuất." />
                <TextBlock Text="• Nếu máy không in được ngay, hệ thống vẫn cho xuất file để in sau." />
                <TextBlock Text="• Trước khi in chính thức, nên xem lại số liệu và bố cục file đã xuất." />
                <TextBlock Text="• Hệ thống có lưu lại lịch sử thao tác xuất và in để tiện đối chiếu khi cần." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

