<UserControl x:Class="CoffeeShop.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  
                  >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardPanel}" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleText}" Text="Bảng điều khiển" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource PageSubtitleText}"
                                   Text="Theo dõi nhanh doanh thu, tồn kho và hành động cần xử lý trong ngày." />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Width="110"
                                Content="Tải lại"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding TaiLaiCommand}" />
                        <Button Width="130"
                                Margin="8,0,0,0"
                                Content="Mở thống kê"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding MoThongKeCommand}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Doanh thu hôm nay" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding DoanhThuHomNay, StringFormat={}{0:N0} đ}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Số hóa đơn hôm nay" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding SoHoaDonHomNay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Sản phẩm đang kinh doanh" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding SoSanPhamDangKinhDoanh}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource PageSubtitleText}"
                                   Text="{Binding TyLeSanPhamDangKinhDoanh, StringFormat=Tỷ lệ hoạt động: {0:N2}%}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource CardPanelMuted}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="Món sắp hết hàng" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Text="{Binding SoSanPhamSapHet}" />
                        <Border Margin="0,8,0,0"
                                Style="{StaticResource StatusBadgeWarning}">
                            <TextBlock Text="Cần kiểm tra nhập kho"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningBrush}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.65*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitleText}" Text="Doanh thu 7 ngày gần nhất" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource PageSubtitleText}"
                                       Text="Kết quả doanh thu tuần vừa qua" />
                        </StackPanel>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding DoanhThu7Ngay}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ngày"
                                                    Binding="{Binding Ngay, StringFormat=dd/MM/yyyy}"
                                                    Width="*" />
                                
                                <DataGridTextColumn Header="Số HĐ"
                                                    Binding="{Binding SoHoaDon}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="*" />
                                
                                <DataGridTextColumn Header="Doanh thu thuần"
                                                    Binding="{Binding DoanhThuThuan, StringFormat={}{0:N0} đ}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource CardTitleText}" Text="Top bán chạy hôm nay" />

                        <DataGrid Grid.Row="2" ItemsSource="{Binding TopSanPhamHomNay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="72" />
                                <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="*" />
                                <DataGridTextColumn Header="SL bán"
                                                    Binding="{Binding TongSoLuongBan}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="86" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="3"
                                Content="Mở chi tiết top sản phẩm"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding MoTopSanPhamCommand}" />
                    </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource CardTitleText}" Text="Tồn kho thấp" />

                        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachTonKhoThap}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="72" />
                                <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="*" />
                                <DataGridTextColumn Header="Tồn"
                                                    Binding="{Binding TonKho}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="70" />
                                <DataGridTextColumn Header="Ngưỡng"
                                                    Binding="{Binding MucCanhBaoTonKho}"
                                                    ElementStyle="{StaticResource RightAlignedCellText}"
                                                    Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="3"
                                Content="Mở cảnh báo tồn kho"
                                Style="{StaticResource ButtonWarning}"
                                Command="{Binding MoTonKhoThapCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <TextBlock Foreground="{DynamicResource DangerBrush}" Text="{Binding ErrorMessage}" />
                <TextBlock Foreground="{DynamicResource SuccessBrush}" Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
