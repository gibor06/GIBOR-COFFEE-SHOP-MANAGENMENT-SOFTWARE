<UserControl x:Class="CoffeeShop.Wpf.Views.CanhBaoTonKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Cảnh báo tồn kho thấp"
                           FontSize="20"
                           FontWeight="SemiBold" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Padding="10,6"
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding DanhMucs}"
                              SelectedItem="{Binding SelectedDanhMuc, Mode=TwoWay}"
                              DisplayMemberPath="TenDanhMuc"
                              Padding="8,4" />

                    <Button Grid.Column="4"
                            Width="120"
                            Content="Tải danh sách"
                            Command="{Binding TaiDanhSachCommand}" />

                    <Button Grid.Column="6"
                            Width="95"
                            Content="Làm mới"
                            Command="{Binding LamMoiCommand}"
                            Background="{DynamicResource SecondaryBrush}"
                            BorderBrush="{DynamicResource SecondaryBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}" />
                </Grid>

                <TextBlock Margin="0,10,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="12">
            <DataGrid ItemsSource="{Binding DanhSachCanhBao}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="70" />
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                    <DataGridTextColumn Header="Danh mục" Binding="{Binding TenDanhMuc}" Width="150" />
                    <DataGridTextColumn Header="Tồn kho" Binding="{Binding TonKho}" Width="100" />
                    <DataGridTextColumn Header="Ngưỡng cảnh báo" Binding="{Binding MucCanhBaoTonKho}" Width="130" />
                    <DataGridTextColumn Header="Cần bổ sung" Binding="{Binding SoLuongCanBoSung}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

