<UserControl x:Class="CoffeeShop.Wpf.Views.CaLamViecView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Ca làm việc"
                           FontSize="20"
                           FontWeight="SemiBold" />

                <TextBlock Margin="0,10,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding CaDangMo.CaLamViecId, StringFormat=Ca đang mở: #{0}}" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding CaDangMo.ThoiGianMoCa, StringFormat=Thời gian mở: {0:dd/MM/yyyy HH:mm}}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding CaDangMo.TongDoanhThu, StringFormat=Doanh thu hiện tại: {0:N0}}" />

                <WrapPanel Margin="0,12,0,0">
                    <TextBlock VerticalAlignment="Center" Text="Ghi chú ca:" />
                    <TextBox Width="300"
                             Margin="8,0,0,0"
                             Padding="10,6"
                             Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Width="100"
                            Margin="10,0,0,0"
                            Content="Mở ca"
                            Command="{Binding MoCaCommand}" />
                    <Button Width="100"
                            Margin="8,0,0,0"
                            Content="Đóng ca"
                            Command="{Binding DongCaCommand}"
                            Background="{DynamicResource SecondaryBrush}"
                            BorderBrush="{DynamicResource SecondaryBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}" />
                </WrapPanel>

                <WrapPanel Margin="0,12,0,0">
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                    <DatePicker Margin="8,0,0,0" SelectedDate="{Binding ToDate, Mode=TwoWay}" />
                    <Button Width="130"
                            Margin="10,0,0,0"
                            Content="Tải lịch sử ca"
                            Command="{Binding TaiLichSuCaCommand}" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="12">
            <DataGrid ItemsSource="{Binding LichSuCa}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã ca" Binding="{Binding CaLamViecId}" Width="80" />
                    <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="*" />
                    <DataGridTextColumn Header="Mở ca" Binding="{Binding ThoiGianMoCa, StringFormat=dd/MM/yyyy HH:mm}" Width="145" />
                    <DataGridTextColumn Header="Đóng ca" Binding="{Binding ThoiGianDongCa, StringFormat=dd/MM/yyyy HH:mm}" Width="145" />
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThaiCaHienThi}" Width="100" />
                    <DataGridTextColumn Header="Số hóa đơn" Binding="{Binding SoHoaDon}" Width="95" />
                    <DataGridTextColumn Header="Doanh thu" Binding="{Binding TongDoanhThu, StringFormat=N0}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

