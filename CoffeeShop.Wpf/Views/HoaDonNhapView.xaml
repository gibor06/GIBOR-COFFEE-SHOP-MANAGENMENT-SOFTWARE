<UserControl x:Class="CoffeeShop.Wpf.Views.HoaDonNhapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1200">
    
   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="350" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleText}" Text="Hóa đơn nhập" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource PageSubtitleText}"
                           Text="Lập phiếu nhập theo nhà cung cấp, kiểm tra tổng tiền và lưu chứng từ nhanh." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleText}" Text="Thông tin chứng từ" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Nhà cung cấp" />
                            <ComboBox ItemsSource="{Binding NhaCungCaps}"
                                      SelectedItem="{Binding SelectedNhaCungCap, Mode=TwoWay}"
                                      DisplayMemberPath="TenNhaCungCap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Ghi chú" />
                            <TextBox Height="70"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,12,0,0"
                            Style="{StaticResource CardPanelMuted}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Mons}"
                                      SelectedItem="{Binding SelectedMon, Mode=TwoWay}"
                                      DisplayMemberPath="TenMon" />

                            <TextBox Grid.Column="2"
                                     Text="{Binding SoLuongNhap, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBox Grid.Column="4"
                                     Text="{Binding DonGiaNhap, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Column="6"
                                    Width="130"
                                    Content="Thêm dòng"
                                    Style="{StaticResource ButtonPrimary}"
                                    Command="{Binding ThemDongCommand}" />
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource CaptionText}"
                               Text="Gợi ý: Chọn sản phẩm, nhập số lượng và đơn giá trước khi thêm vào bảng chi tiết." />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleText}" Text="Tổng hợp" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="{Binding TongTien, StringFormat=Tổng tiền: {0:N0} đ}" />

                    <Button Content="Lưu hóa đơn"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding LuuHoaDonCommand}" />
                    <Button Content="Làm mới"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding LamMoiCommand}" />
                    <Button Content="Xóa dòng chọn"
                            Style="{StaticResource ButtonDanger}"
                            Command="{Binding XoaDongCommand}" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource CardTitleText}" Text="Chi tiết phiếu nhập" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding ChiTietLines}"
                          SelectedItem="{Binding SelectedDongChiTiet, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã món" Binding="{Binding MonId}" Width="88" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                        <DataGridTextColumn Header="Số lượng"
                                            Binding="{Binding SoLuong}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="100" />
                        <DataGridTextColumn Header="Đơn giá nhập"
                                            Binding="{Binding DonGiaNhap, StringFormat={}{0:N0} đ}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="140" />
                        <DataGridTextColumn Header="Thành tiền"
                                            Binding="{Binding ThanhTien, StringFormat={}{0:N0} đ}"
                                            ElementStyle="{StaticResource RightAlignedCellText}"
                                            Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
