<UserControl x:Class="CoffeeShop.Wpf.Views.TrangThaiSanPhamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Trạng thái sản phẩm"
                           FontSize="20"
                           FontWeight="SemiBold" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Padding="10,6"
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding DanhMucs}"
                              SelectedItem="{Binding SelectedDanhMucTimKiem, Mode=TwoWay}"
                              DisplayMemberPath="TenDanhMuc"
                              Padding="8,4" />

                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding TrangThaiFilters}"
                              SelectedItem="{Binding SelectedTrangThaiTimKiem, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Padding="8,4" />

                    <Button Grid.Column="6"
                            Width="110"
                            Content="Tìm kiếm"
                            Command="{Binding TimKiemCommand}" />

                    <Button Grid.Column="8"
                            Width="95"
                            Content="Làm mới"
                            Command="{Binding LamMoiCommand}"
                            Background="{DynamicResource SecondaryBrush}"
                            BorderBrush="{DynamicResource SecondaryBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}" />
                </Grid>

                <TextBlock Margin="0,10,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10"
                    Padding="12">
                <DataGrid ItemsSource="{Binding DanhSachSanPham}"
                          SelectedItem="{Binding SelectedSanPham, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="70" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                        <DataGridTextColumn Header="Danh mục" Binding="{Binding TenDanhMuc}" Width="140" />
                        <DataGridTextColumn Header="Tồn kho" Binding="{Binding TonKho}" Width="90" />
                        <DataGridTextColumn Header="Ngưỡng cảnh báo" Binding="{Binding MucCanhBaoTonKho}" Width="120" />
                        <DataGridCheckBoxColumn Header="Đang kinh doanh" Binding="{Binding IsActive}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Thao tác nhanh"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <TextBlock Margin="0,10,0,0"
                               FontWeight="SemiBold"
                               Text="Sản phẩm đang chọn" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding SelectedSanPham.TenMon}" />
                    <TextBlock Margin="0,2,0,0"
                               Text="{Binding SelectedSanPham.TonKho, StringFormat=Tồn kho: {0}}" />
                    <TextBlock Margin="0,2,0,0"
                               Text="{Binding SelectedSanPham.IsActive, StringFormat=Đang kinh doanh: {0}}" />

                    <Button Margin="0,12,0,0"
                            Content="Khóa / mở kinh doanh"
                            Command="{Binding KhoaMoSanPhamCommand}" />

                    <TextBlock Margin="0,14,0,0"
                               Text="Mức cảnh báo tồn kho"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding MucCanhBaoTonKhoInput, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Content="Cập nhật ngưỡng cảnh báo"
                            Command="{Binding CapNhatNguongCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

