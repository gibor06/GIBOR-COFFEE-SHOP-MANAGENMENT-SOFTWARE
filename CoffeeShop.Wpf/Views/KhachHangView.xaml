<UserControl x:Class="CoffeeShop.Wpf.Views.KhachHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="980">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="300" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Khách hàng thân thiết" />
                        <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Lưu thông tin khách hàng để tích điểm và chăm sóc sau bán." />

                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Họ tên" />
                        <TextBox Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" />

                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Số điện thoại" />
                        <TextBox Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}" MaxLength="20" />

                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Email" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" />

                        <CheckBox Margin="0,10,0,0"
                              Content="Đang hoạt động"
                              IsChecked="{Binding IsActive, Mode=TwoWay}" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Thêm"
                                Width="100"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding ThemCommand}" />
                            <Button Content="Sửa"
                                Width="100"
                                Margin="8,0,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding SuaCommand}" />
                            <Button Content="Làm mới"
                                Width="100"
                                Margin="8,0,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                        </WrapPanel>

                        <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                        <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Tìm kiếm" />
                        <TextBox Margin="0,8,0,0"
                             Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="0,8,0,0"
                            Content="Tìm kiếm"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding TimKiemCommand}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                <DataGrid ItemsSource="{Binding DanhSachKhachHang}"
                      SelectedItem="{Binding SelectedKhachHang, Mode=TwoWay}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding KhachHangId}" Width="70" />
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="2*" />
                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="130" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" />
                        <DataGridTextColumn Header="Điểm tích lũy" Binding="{Binding DiemTichLuy}" Width="120" />
                        <DataGridCheckBoxColumn Header="Kích hoạt" Binding="{Binding IsActive}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
