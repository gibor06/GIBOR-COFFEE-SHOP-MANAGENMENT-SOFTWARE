<UserControl x:Class="CoffeeShop.Wpf.Views.CongThucMonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Form nhập liệu -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Quản lý công thức món" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Chọn món và thêm nguyên liệu với định lượng cụ thể." />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Chọn món" />
                <ComboBox ItemsSource="{Binding Mons}"
                          SelectedItem="{Binding SelectedMon, Mode=TwoWay}"
                          DisplayMemberPath="TenMon" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Nguyên liệu" />
                <ComboBox ItemsSource="{Binding NguyenLieus}"
                          SelectedItem="{Binding SelectedNguyenLieu, Mode=TwoWay}"
                          DisplayMemberPath="TenNguyenLieu"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          TextSearch.TextPath="TenNguyenLieu" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="SemiBold" Text="Định lượng" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DinhLuong, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DonViTinhHienThi}"
                                       VerticalAlignment="Center"
                                       Padding="8,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock FontWeight="SemiBold" Text="Tỷ lệ hao hụt (%)" />
                        <TextBox Text="{Binding TyLeHaoHut, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Ghi chú" />
                <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" MaxLength="255" />

                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Các bước thực hiện (hướng dẫn pha chế)" />
                <TextBox Text="{Binding CacBuocThucHien, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="80"
                         MaxHeight="150"
                         VerticalScrollBarVisibility="Auto" />

                <Border Margin="0,12,0,0"
                        Background="{DynamicResource InfoBackgroundBrush}"
                        BorderBrush="{DynamicResource InfoBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Giá vốn ước tính (đã tính hao hụt):" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Text="{Binding GiaVonDaTinhHienThi}" />
                    </StackPanel>
                </Border>

                <WrapPanel Margin="0,14,0,0">
                    <Button Width="140"
                            Content="{Binding ThemNguyenLieuButtonText}"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding ThemNguyenLieuCommand}" />
                </WrapPanel>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <!-- Danh sách nguyên liệu -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Danh sách nguyên liệu trong công thức" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding CongThucMons}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding CongThucMonId}" Width="60" />
                        <DataGridTextColumn Header="Nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="2*" />
                        <DataGridTextColumn Header="Định lượng" Binding="{Binding DinhLuongHienThi}" Width="120" />
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="80" />
                        <DataGridTextColumn Header="Giá vốn" Binding="{Binding GiaVonNguyenLieuHienThi}" Width="100" />
                        <DataGridTextColumn Header="Hao hụt (%)" Binding="{Binding TyLeHaoHut}" Width="90" />
                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="2*" />
                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Sửa"
                                                Width="60"
                                                Margin="0,0,4,0"
                                                Style="{StaticResource ButtonWarning}"
                                                Command="{Binding DataContext.SuaNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Xóa"
                                                Width="60"
                                                Margin="0,0,4,0"
                                                Style="{StaticResource ButtonDanger}"
                                                Command="{Binding DataContext.XoaNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardPanel}" MaxHeight="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="Lịch sử cập nhật công thức" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding LichSuCapNhats}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày giờ" Binding="{Binding NgayCapNhatHienThi}" Width="150" />
                        <DataGridTextColumn Header="Người cập nhật" Binding="{Binding NguoiCapNhat}" Width="150" />
                        <DataGridTextColumn Header="Nội dung" Binding="{Binding NoiDungCapNhat}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
