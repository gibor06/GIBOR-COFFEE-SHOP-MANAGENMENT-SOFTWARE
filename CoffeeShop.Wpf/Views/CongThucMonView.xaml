<UserControl x:Class="CoffeeShop.Wpf.Views.CongThucMonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="980">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Quản lý công thức món" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Chọn món và thêm nguyên liệu với định lượng cụ thể." />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Chọn món" />
                <ComboBox ItemsSource="{Binding Mons}"
                          SelectedItem="{Binding SelectedMon, Mode=TwoWay}"
                          DisplayMemberPath="TenMon" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="SemiBold" Text="Nguyên liệu" />
                        <ComboBox ItemsSource="{Binding NguyenLieus}"
                                  SelectedItem="{Binding SelectedNguyenLieu, Mode=TwoWay}"
                                  DisplayMemberPath="TenNguyenLieu" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock FontWeight="SemiBold" Text="Định lượng" />
                        <TextBox Text="{Binding DinhLuong, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Ghi chú" />
                <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" MaxLength="255" />

                <WrapPanel Margin="0,14,0,0">
                    <Button Width="140"
                            Content="Thêm nguyên liệu"
                            Style="{StaticResource ButtonPrimary}"
                            Command="{Binding ThemNguyenLieuCommand}" />
                </WrapPanel>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SuccessBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding SuccessMessage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Danh sách nguyên liệu trong công thức" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding CongThucMons}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding CongThucMonId}" Width="80" />
                        <DataGridTextColumn Header="Nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="2*" />
                        <DataGridTextColumn Header="Định lượng" Binding="{Binding DinhLuongHienThi}" Width="140" />
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="100" />
                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="2*" />
                        <DataGridTemplateColumn Header="Thao tác" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa"
                                            Style="{StaticResource ButtonDanger}"
                                            Command="{Binding DataContext.XoaNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
