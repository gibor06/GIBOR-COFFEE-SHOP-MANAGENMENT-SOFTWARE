<UserControl x:Class="CoffeeShop.Wpf.Views.MonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="980">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Quản lý sản phẩm" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Tạo nhanh sản phẩm mới và quản lý thông tin giá, tồn kho ban đầu." />

                    <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Tên sản phẩm" />
                    <TextBox Text="{Binding TenMon, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" />

                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Danh mục" />
                    <ComboBox ItemsSource="{Binding DanhMucs}"
                              SelectedItem="{Binding SelectedDanhMucTaoMoi, Mode=TwoWay}"
                              DisplayMemberPath="TenDanhMuc" />

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Text="Đơn giá" />
                            <TextBox Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Text="Tồn kho ban đầu" />
                            <TextBox Text="{Binding TonKhoBanDau, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Đường dẫn hình ảnh" />
                    <TextBox Text="{Binding HinhAnhPath, UpdateSourceTrigger=PropertyChanged}" />

                    <WrapPanel Margin="0,14,0,0">
                        <Button Width="120"
                                Content="Tạo mới"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TaoMoiCommand}" />
                        <Button Width="100"
                                Margin="8,0,0,0"
                                Content="Làm mới"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                    </WrapPanel>

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SuccessMessage}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Bộ lọc tìm kiếm" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Lọc nhanh theo từ khóa hoặc danh mục để thao tác chính xác hơn." />

                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Từ khóa" />
                    <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Danh mục" />
                    <ComboBox ItemsSource="{Binding DanhMucs}"
                              SelectedItem="{Binding SelectedDanhMucTimKiem, Mode=TwoWay}"
                              DisplayMemberPath="TenDanhMuc" />

                    <WrapPanel Margin="0,14,0,0">
                        <Button Width="110"
                                Content="Tìm kiếm"
                                Style="{StaticResource ButtonPrimary}"
                                Command="{Binding TimKiemCommand}" />
                        <Button Width="110"
                                Margin="8,0,0,0"
                                Content="Làm mới"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding LamMoiCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Danh sách sản phẩm" />

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Mons}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MonId}" Width="80" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenMon}" Width="2*" />
                        <DataGridTextColumn Header="Danh mục" Binding="{Binding TenDanhMuc}" Width="160" />
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat=N0}" Width="120" />
                        <DataGridTextColumn Header="Tồn kho" Binding="{Binding TonKho}" Width="100" />
                        <DataGridTextColumn Header="Hình ảnh" Binding="{Binding HinhAnhPath}" Width="2*" />
                        <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
